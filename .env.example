# Copy this file to .env and fill in your own values.

# MongoDB Atlas connection string. In Atlas: Database > Connect > Drivers.
# Example shape (replace user/pass/cluster/db):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/webcrump?retryWrites=true&w=majority

# Any long random string -- used to sign session cookies.
SESSION_SECRET=replace-this-with-a-long-random-string

# Port the app listens on locally (Render/Vercel set this automatically in production).
PORT=3000

NODE_ENV=development
