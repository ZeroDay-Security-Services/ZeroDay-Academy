<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="brand">
      <img src="/img/logo.png" alt="ZeroDay Security Services">
      <span>ZeroDay Academy<span class="brand-sub">by ZeroDay Security Services</span></span>
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">&#9776;</button>
    <div class="nav-links" id="navLinks">
      <a href="/challenges">Challenges</a>
      <a href="/leaderboard">Leaderboard</a>
      <a href="/company">Company</a>
      <% if (currentUser) { %>
        <a href="/dashboard">Dashboard</a>
      <% } %>
      <div class="nav-cta" style="display:flex; gap:0.6rem; margin-top:0.5rem;">
        <% if (currentUser) { %>
          <span class="points-chip">⚡ <%= currentUser.points %> pts</span>
          <a href="/profile" class="btn btn-ghost btn-sm"><%= currentUser.username %></a>
          <form action="/logout" method="POST" style="margin:0;">
            <button type="submit" class="btn btn-ghost btn-sm">Sign out</button>
          </form>
        <% } else { %>
          <a href="/login" class="btn btn-ghost btn-sm">Sign in</a>
          <a href="/register" class="btn btn-primary btn-sm">Get started</a>
        <% } %>
      </div>
    </div>
    <div class="nav-cta" id="navCtaDesktop">
      <% if (currentUser) { %>
        <span class="points-chip">⚡ <%= currentUser.points %> pts</span>
        <a href="/profile" class="btn btn-ghost btn-sm"><%= currentUser.username %></a>
        <form action="/logout" method="POST" style="margin:0;">
          <button type="submit" class="btn btn-ghost btn-sm">Sign out</button>
        </form>
      <% } else { %>
        <a href="/login" class="btn btn-ghost btn-sm">Sign in</a>
        <a href="/register" class="btn btn-primary btn-sm">Get started</a>
      <% } %>
    </div>
  </div>
</nav>
<style>
  @media (max-width: 880px) { #navCtaDesktop { display: none; } }
  @media (min-width: 881px) { .nav-links .nav-cta { display: none !important; } }
</style>
<script>
  document.getElementById('navToggle').addEventListener('click', function () {
    document.getElementById('navLinks').classList.toggle('open');
  });
</script>
