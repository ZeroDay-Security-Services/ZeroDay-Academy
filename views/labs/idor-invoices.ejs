<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BillPeak — My Invoices</title>
<link rel="stylesheet" href="/css/lab.css">
</head>
<body data-theme="access">
<div class="lab-topbar"><a class="lab-back" href="/challenges">&larr; ZeroDay Academy</a><span class="name">BillPeak</span><span class="tag">/labs/idor-invoices · logged in as guest</span></div>
<div class="lab-wrap">
  <div class="lab-card">
    <h1>My Invoices</h1>
    <table class="lab-table">
      <thead><tr><th>ID</th><th>Amount</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% myInvoices.forEach(inv => { %>
          <tr>
            <td>#<%= inv.invoiceNumber %></td>
            <td><%= inv.amount %></td>
            <td><%= inv.status %></td>
            <td><a class="lab-link" href="/labs/idor-invoices/invoice/<%= inv.invoiceNumber %>">View</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="lab-card">
    <h2>View invoice by ID</h2>
    <form method="GET" action="" onsubmit="window.location='/labs/idor-invoices/invoice/'+this.id.value; return false;">
      <label>Invoice ID</label>
      <input id="id" name="id" type="number" min="1" placeholder="e.g. 1">
      <button type="submit">Fetch invoice</button>
    </form>

    <% if (error) { %><div class="lab-alert error"><%= error %></div><% } %>
    <% if (invoice) { %>
      <div class="lab-alert <%= invoice.ownerUsername === 'guest' ? 'success' : 'info' %>">
        <strong>Invoice #<%= invoice.invoiceNumber %></strong> — owner: <%= invoice.ownerUsername %><br>
        Amount: <%= invoice.amount %><br>
        Status: <%= invoice.status %>
      </div>
    <% } %>
  </div>

</body>
</html>
