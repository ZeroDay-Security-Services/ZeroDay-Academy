<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CloudProfile — Avatar Importer</title>
<link rel="stylesheet" href="/css/lab.css">
</head>
<body data-theme="ssrf">
<div class="lab-topbar"><a class="lab-back" href="/challenges">&larr; ZeroDay Academy</a><span class="name">CloudProfile</span><span class="tag">/labs/ssrf-metadata</span></div>
<div class="lab-wrap">
  <div class="lab-card">
    <h1>Import avatar from URL</h1>
    <p>Paste a URL and the server will fetch it on your behalf and show you the response.</p>
    <form method="POST" action="/labs/ssrf-metadata">
      <label>Image URL</label>
      <input name="url" value="<%= url %>" placeholder="https://example.com/avatar.png">
      <button type="submit">Fetch</button>
    </form>
    <% if (error) { %><div class="lab-alert error"><%= error %></div><% } %>
    <% if (result) { %>
      <p class="lab-meta" style="margin-top:1rem;">Server response (status <%= result.status %>, via <%= result.via %>)</p>
      <div class="lab-code"><%= result.body %></div>
    <% } %>
  </div>
  

</body>
</html>
