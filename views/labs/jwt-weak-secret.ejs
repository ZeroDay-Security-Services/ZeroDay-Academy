<%- include('_top', { appName: 'ApiGateway', pageTitle: 'Token Playground', theme: 'auth', tag: '/labs/jwt-weak-secret' }) %>
<div class="lab-card">
  <h1>Your issued token</h1>
  <div class="lab-code"><%= issuedToken %></div>
</div>
<div class="lab-card">
  <h2>Verify a token</h2>
  <p>This time the signature is genuinely checked -- but the secret used to sign it is weak.</p>
  <form method="POST" action="/labs/jwt-weak-secret/verify">
    <label>Token</label>
    <textarea name="token" rows="3"><%= submittedToken %></textarea>
    <button type="submit">Verify</button>
  </form>
  <% if (error) { %><div class="lab-alert error">Verification failed: <%= error %></div><% } %>
  <% if (verifyResult) { %><div class="lab-code"><%= JSON.stringify(verifyResult, null, 2) %></div><% } %>
  <% if (flag) { %><div class="lab-alert success">Admin claim accepted. Flag: <span class="lab-flag"><%= flag %></span></div><% } %>
</div>

<%- include('_bottom') %>
