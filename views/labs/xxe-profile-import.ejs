<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HRSuite — Bulk Profile Import</title>
<link rel="stylesheet" href="/css/lab.css">
</head>
<body data-theme="xxe">
<div class="lab-topbar"><a class="lab-back" href="/challenges">&larr; ZeroDay Academy</a><span class="name">HRSuite</span><span class="tag">/labs/xxe-profile-import</span></div>
<div class="lab-wrap">
  <div class="lab-card">
    <h1>Import profile XML</h1>
    <p>Paste an XML profile document to import it. The parser processes DOCTYPE declarations and external entities.</p>
    <form method="POST" action="/labs/xxe-profile-import">
      <label>XML</label>
      <textarea name="xml" rows="10"><%= xmlInput %></textarea>
      <button type="submit">Import</button>
    </form>
    <% if (error) { %><div class="lab-alert error"><%= error %></div><% } %>
    <% if (result) { %>
      <p class="lab-meta" style="margin-top:1rem;">Parsed displayName field</p>
      <div class="lab-code"><%= result.displayName %></div>
    <% } %>
  </div>
  

</body>
</html>
