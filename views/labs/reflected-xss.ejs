<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SecureShop — Search</title>
<link rel="stylesheet" href="/css/lab.css">
</head>
<body data-theme="xss">
<div class="lab-topbar"><a class="lab-back" href="/challenges">&larr; ZeroDay Academy</a><span class="name">SecureShop</span><span class="tag">/labs/reflected-xss</span></div>
<div class="lab-wrap">
  <div class="lab-card">
    <h1>Product Search</h1>
    <form method="GET" action="/labs/reflected-xss">
      <div class="lab-row">
        <div><input name="q" placeholder="Search products..." value="<%= q %>"></div>
        <div style="flex:0;"><button type="submit">Search</button></div>
      </div>
    </form>
    <% if (q) { %>
      <!-- VULNERABLE: `q` is injected into the page unescaped -->
      <p>Showing results for: <%- q %></p>
    <% } %>
  </div>

  <div class="lab-card">
    <ul class="lab-list">
      <% matches.forEach(p => { %>
        <li><%= p.name %> <span class="lab-meta" style="float:right;"><%= p.price %></span></li>
      <% }) %>
      <% if (matches.length === 0) { %><li class="lab-meta">No products matched.</li><% } %>
    </ul>
  </div>

  

</body>
</html>
