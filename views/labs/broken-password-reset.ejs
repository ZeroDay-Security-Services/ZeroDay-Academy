<%- include('_top', { appName: 'AccountCare', pageTitle: 'Password Reset', theme: 'auth', tag: '/labs/broken-password-reset' }) %>
<div class="lab-card">
  <h1>Request a password reset</h1>
  <form method="POST" action="/labs/broken-password-reset/request-reset">
    <label>Username</label>
    <input name="username" placeholder="guest">
    <button type="submit">Send reset email</button>
  </form>
  <% if (issuedToken) { %><div class="lab-alert info">(Simulated email) Your reset token: <code><%= issuedToken %></code></div><% } %>
</div>
<div class="lab-card">
  <h2>Complete reset</h2>
  <form method="POST" action="/labs/broken-password-reset/complete-reset">
    <label>Reset token</label>
    <input name="token" placeholder="RST-1001">
    <label>New password</label>
    <input name="newPassword" type="password" placeholder="newpass123">
    <button type="submit">Reset password</button>
  </form>
  <% if (error) { %><div class="lab-alert error"><%= error %></div><% } %>
  <% if (result) { %>
    <div class="lab-alert <%= result.flag ? 'success' : 'info' %>">
      Reset completed for account: <strong><%= result.owner %></strong>
      <% if (result.flag) { %><br>Flag: <span class="lab-flag"><%= result.flag %></span><% } %>
    </div>
  <% } %>
</div>

<%- include('_bottom') %>
